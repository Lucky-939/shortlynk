# ShortLynk frontend — environment variables
# Copy to .env.local for local development. Never commit .env.local.

# Worker base URLs — no trailing slash
NEXT_PUBLIC_AUTH_API_URL=http://localhost:8790
NEXT_PUBLIC_SHORTEN_API_URL=http://localhost:8787
NEXT_PUBLIC_ANALYTICS_API_URL=http://localhost:8791

# Public-facing redirect base — the URL shown to users in short links.
# This points to redirect-worker (8788), NOT shorten-worker (8787).
# In production, set this to your redirect domain (e.g. https://sho.rt).
NEXT_PUBLIC_REDIRECT_BASE_URL=http://localhost:8788
